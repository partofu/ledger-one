# Database Connection
# Replace with your actual database and direct URLs for your VPS / Vercel
DATABASE_URL="postgres://user:password@host:5432/packledger"
DIRECT_URL="postgres://user:password@host:5432/packledger"

# Authentication Config
# Must match in production, and keep secretly generated
JWT_SECRET="generate_a_strong_random_secret_here"

# SMTP Email Configuration for sending OTPs
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
